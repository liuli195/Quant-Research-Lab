{
  "version": 1,
  "build": {
    "checks": [
      {
        "id": "build.placeholder",
        "command": [
          ".\\.venv\\Scripts\\python.exe",
          "scripts\\build_placeholder.py"
        ],
        "inputs": [
          "scripts/build_placeholder.py"
        ]
      }
    ]
  },
  "verify": {
    "maxParallel": 0,
    "timeoutSeconds": 180,
    "checks": [
      {
        "id": "verify.python-tests",
        "command": [
          ".\\.venv\\Scripts\\python.exe",
          "-m",
          "pytest"
        ],
        "paths": [
          "joinquant/**",
          "scripts/**",
          "tests/**",
          "requirements*.txt"
        ],
        "inputs": [
          "joinquant/**",
          "scripts/**",
          "tests/**",
          "requirements.txt",
          "requirements-dev.txt"
        ],
        "checkParallel": true,
        "pytestXdistWorkers": "auto"
      },
      {
        "id": "verify.openspec",
        "command": "openspec validate --all --strict --no-interactive",
        "paths": [
          "openspec/**"
        ],
        "inputs": [
          "openspec/**"
        ],
        "checkParallel": true
      }
    ]
  }
}
