{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "analysis_plan",
    "benchmark_manifest",
    "baseline_scenario_id",
    "sources"
  ],
  "properties": {
    "schema_version": {"const": "standard-analysis-source-registry/1"},
    "analysis_plan": {"type": "string", "minLength": 1},
    "benchmark_manifest": {"type": "string", "minLength": 1},
    "baseline_scenario_id": {"type": "string", "minLength": 1},
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["scenario_id", "path", "source_type", "manifest_sha256"],
        "properties": {
          "scenario_id": {"type": "string", "minLength": 1},
          "path": {"type": "string", "minLength": 1},
          "source_type": {
            "enum": [
              "local_research",
              "joinquant_backtest",
              "joinquant_simulation"
            ]
          },
          "manifest_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "snapshot_id": {"type": "string", "minLength": 1}
        },
        "allOf": [
          {
            "if": {"properties": {"source_type": {"const": "joinquant_simulation"}}},
            "then": {"required": ["snapshot_id"]},
            "else": {"not": {"required": ["snapshot_id"]}}
          }
        ]
      }
    }
  }
}
